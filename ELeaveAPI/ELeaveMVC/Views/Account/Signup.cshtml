@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>E-Leave — Signup</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/css/bootstrap.min.css">
</head>
<body class="bg-primary d-flex align-items-center" style="min-height:100vh">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow-lg p-4 mt-5">
                    <h4 class="text-center text-primary mb-1">E-Leave System</h4>
                    <p class="text-center text-muted mb-4">Employee Self-Service</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2">@ViewBag.Error</div>
                    }
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success py-2">@TempData["Message"]</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Full Name</label>
                            <input name="fullName" class="form-control" required autofocus />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Username</label>
                            <input name="username" class="form-control" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Password</label>
                            <input name="password" type="password" class="form-control" required />
                        </div>
                        <button class="btn btn-primary w-100 py-2">Sign Up</button>
                    </form>

                    <hr class="my-3" />

                    <div class="text-center">
                        <p class="mb-0">
                            Already have an account?
                            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary btn-sm ms-1">Login</a>
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</body>
</html>